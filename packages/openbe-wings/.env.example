# ─────────────────────────────────────────────────────────────────────────────
# OpenBe Wings 环境变量示例 / OpenBe Wings environment variables example
#
# 使用方法 / How to use:
#   cp .env.example .env
#   # 编辑 .env，填入真实值 / Edit .env and fill in real values
#
# 注意：.env 文件包含敏感信息，不要提交到版本控制系统！
# Note: .env contains sensitive secrets — never commit it to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ─── 飞书 (Feishu / Lark) 应用配置 ───────────────────────────────────────────
# 在飞书开放平台「我的应用」→「凭证与基础信息」中获取
# Found in Feishu Open Platform → My Apps → Credentials & Basic Info

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 在「事件订阅」页面的「验证令牌」处获取
# Found on the "Event Subscription" page under "Verification Token"
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 消息加密密钥（可选）。若不启用加密，保持空值即可
# Message encrypt key (optional). Leave empty if encryption is disabled.
FEISHU_ENCRYPT_KEY=

# ─── 企业微信 (WeWork / WeCom) 配置 ──────────────────────────────────────────
# 在企业微信管理后台「我的企业」→「企业信息」中获取 Corp ID
# Corp ID found in WeWork Admin → My Enterprise → Enterprise Info
WEWORK_CORP_ID=wwxxxxxxxxxxxxxxxx

# 在「应用管理」→ 具体应用的「Secret」中获取
# Corp Secret found in WeWork Admin → App Management → App Secret
WEWORK_CORP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 在「接收消息」服务器配置中自行设置的 Token（随机字符串）
# Token set by you in WeWork Admin → Receive Messages → Server Config
WEWORK_TOKEN=xxxxxxxxxxxxxxxx

# 在「接收消息」服务器配置中自动生成的 EncodingAESKey（43 位）
# EncodingAESKey auto-generated in WeWork Admin → Receive Messages → Server Config (43 chars)
WEWORK_ENCODING_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 应用 AgentId，在「应用管理」→ 具体应用详情页获取
# Agent ID found in WeWork Admin → App Management → App Detail
WEWORK_AGENT_ID=1000001

# ─── OpenBe Queen 配置 ───────────────────────────────────────────────────────
# openbe-queen 服务地址（Wings 将消息转发到此地址）
# openbe-queen service URL (Wings forwards messages here)
OPENBE_QUEEN_URL=http://localhost:8080

# 对话 Hive ID，对应 queen 中的应用/会话实例
# Hive ID corresponding to a conversation/app instance in queen
OPENBE_HIVE_ID=default

# ─── Wings 服务配置 ───────────────────────────────────────────────────────────
# Wings 服务监听端口（默认 8081）
# Wings service listening port (default: 8081)
WINGS_PORT=8081
